.ipynb_checkpoints
*.ipynb
*.ipynb_checkpoints

# Data files
data/raw/*.csv
data/cleaned/*.csv
data/backup/
*.db
*.sqlite

# Logs
logs/
*.log

# Reports
reports/*.png
reports/*.html
reports/*.pdf
reports/*.json

# Dashboard
dashboard/__pycache__/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/

# Distribution
dist/
build/
*.egg-info/

# Environment variables
.env
.env.local

# Config files with secrets
config/local.yaml
config/secrets.yaml

# Temporary files
tmp/
temp/
*.tmp